\set QUIET 1

select
  (:'DBNAME' ilike '%_prod' or :'DBNAME' ilike '%_production') as is_prod,
  (:'DBNAME' ilike '%_stag' or :'DBNAME' ilike '%_staging') as is_stag,
  (:'DBNAME' ilike '%_dev' or :'DBNAME' ilike '%_development') as is_dev,
  (:'DBNAME' ilike '%_test' or :'DBNAME' ilike '%_testing') as is_test \gset

\pset null '[NULL]'
\x
\timing
\pset pager 0
--\pset linestyle unicode
--\pset border 2

-- good for explain format json
-- \pset format unaligned 
-- good for everything else
\pset format wrapped
\set u '\\pset format unaligned'
\set w '\\pset format wrapped'

\set HISTFILE ~/.local/psql/psql_history- :DBNAME
\set HISTCONTROL ignoredups
\set COMP_KEYWORD_CASE lower

\set PROMPT1 '%n@%/%R%#%x '
\set PROMPT2 '[more] %R> '

\set version 'select version();'
\set extensions 'select * from pg_available_extensions;'

-- queries shamelessly stolen from http://github.com/gmcabrita/dotfiles
\set activity `cat ~/.local/psql/queries/activity.sql`
\set analyze_vacuum_stats `cat ~/.local/psql/queries/analyze_vacuum_stats.sql`
\set autovacuum_newest `cat ~/.local/psql/queries/autovacuum_newest.sql`
\set autovacuum_oldest `cat ~/.local/psql/queries/autovacuum_oldest.sql`
\set autovacuum_progress_and_queue `cat ~/.local/psql/queries/autovacuum_progress_and_queue.sql`
\set blockers_of_queries_all `cat ~/.local/psql/queries/blockers_of_queries_all.sql`
\set blockers_of_queries_alter_table `cat ~/.local/psql/queries/blockers_of_queries_alter_table.sql`
\set btree_bloat_estimation `cat ~/.local/psql/queries/btree_bloat_estimation.sql`
\set btree_reindex_candidates `cat ~/.local/psql/queries/btree_reindex_candidates.sql`
\set buffer_cache_usage `cat ~/.local/psql/queries/buffer_cache_usage.sql`
\set cache_hit_ratio_indices `cat ~/.local/psql/queries/cache_hit_ratio_indices.sql`
\set cache_hit_ratio_tables `cat ~/.local/psql/queries/cache_hit_ratio_tables.sql`
\set connection_counts_by_application `cat ~/.local/psql/queries/connection_counts_by_application.sql`
\set connection_counts_by_state `cat ~/.local/psql/queries/connection_counts_by_state.sql`
\set connection_memory_breakdown `cat ~/.local/psql/queries/connection_memory_breakdown.sql`
\set connection_memory_breakdown_by_state `cat ~/.local/psql/queries/connection_memory_breakdown_by_state.sql`
\set connection_total_memory_overhead `cat ~/.local/psql/queries/connection_total_memory_overhead.sql`
\set databases `cat ~/.local/psql/queries/databases.sql`
\set hot_update_ratio `cat ~/.local/psql/queries/hot_update_ratio.sql`
\set index_monitoring `cat ~/.local/psql/queries/index_monitoring.sql`
\set invalid_indexes `cat ~/.local/psql/queries/invalid_indexes.sql`
\set io_cache_hit_ratio `cat ~/.local/psql/queries/io_cache_hit_ratio.sql`
\set io_client_fsync_impact `cat ~/.local/psql/queries/io_client_fsync_impact.sql`
\set io_vacuum_impact `cat ~/.local/psql/queries/io_vacuum_impact.sql`
\set kill_autovacuums `cat ~/.local/psql/queries/kill_autovacuums.sql`
\set lock_trees `cat ~/.local/psql/queries/lock_trees.sql`
\set lock_trees_detailed `cat ~/.local/psql/queries/lock_trees_detailed.sql`
\set long_running `cat ~/.local/psql/queries/running_2_minutes.sql`
\set multixact_size `cat ~/.local/psql/queries/multixact_size.sql`
\set multixact_size_11 `cat ~/.local/psql/queries/multixact_size_11.sql`
\set non_indexed_fks `cat ~/.local/psql/queries/non_indexed_fks.sql`
\set pg_stat_statements_report `cat ~/.local/psql/queries/pg_stat_statements_report.sql`
\set pg_stat_statements_top_total `cat ~/.local/psql/queries/pg_stat_statements_top_total.sql`
\set rare_indexes `cat ~/.local/psql/queries/rare_indexes.sql`
\set redundant_indexes `cat ~/.local/psql/queries/redundant_indexes.sql`
\set running_2_minutes `cat ~/.local/psql/queries/running_2_minutes.sql`
\set running_30_seconds `cat ~/.local/psql/queries/running_30_seconds.sql`
\set table_ages `cat ~/.local/psql/queries/table_ages.sql`
\set table_bloat_estimation `cat ~/.local/psql/queries/table_bloat_estimation.sql`
\set table_read_write_ratios `cat ~/.local/psql/queries/table_read_write_ratios.sql`
\set tables `cat ~/.local/psql/queries/tables.sql`
\set indexes `cat ~/.local/psql/queries/indexes.sql`
\set indexes_timescaledb `cat ~/.local/psql/queries/indexes_timescaledb.sql`
\set tables_missing_pk `cat ~/.local/psql/queries/tables_missing_pk.sql`
\set vacuum_activity `cat ~/.local/psql/queries/vacuum_activity.sql`

\unset QUIET
\set dba '\\i /Users/pineman/.local/psql/postgres_dba/start.psql'
